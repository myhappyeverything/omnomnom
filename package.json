{
  "name": "omnomnom",
  "private": true,
  "version": "0.1.0",
  "description": "OmNomNom — personal nutrition & health tracker",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @omnomnom/web",
    "dev:api": "npm run dev -w @omnomnom/api",
    "build": "npm run build -w @omnomnom/shared && npm run build -w @omnomnom/web && npm run build -w @omnomnom/api",
    "build:web": "npm run build -w @omnomnom/shared && npm run build -w @omnomnom/web",
    "build:api": "npm run build -w @omnomnom/shared && npm run build -w @omnomnom/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "db:migrate:local": "npm run db:migrate:local -w @omnomnom/api",
    "db:migrate:remote": "npm run db:migrate:remote -w @omnomnom/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
